{
  "name": "book-holder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/api\"",
    "import:play": "npm run import:play --workspace=packages/play-importer --",
    "db:migrate": "tsx infra/cockroachdb/migrate.ts"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "concurrently": "^9.0.1",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
